# Apple Developer credentials for code signing and notarization
# Copy this file to .env and fill in your values
#
# TEAM_ID: Your 10-character Apple Developer Team ID
#   Find it at https://developer.apple.com/account → Membership Details
TEAM_ID=

# APPLE_ID: The email address for your Apple Developer account
APPLE_ID=

# APP_PASSWORD: An app-specific password for notarization
#   Generate one at https://appleid.apple.com → Sign-In and Security → App-Specific Passwords
APP_PASSWORD=
